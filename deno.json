{
  "name": "@posaune0423/use-haptic",
  "description": "A convenient React hook to trigger haptic feedback anywhere in your application",
  "version": "1.1.9",
  "imports": {
    "@deno/dnt": "jsr:@deno/dnt@^0.41.3",
    "@std/assert": "jsr:@std/assert@1",
    "@std/testing": "jsr:@std/testing@^1.0.10",
    "@testing-library/react": "npm:@testing-library/react@16",
    "global-jsdom": "npm:global-jsdom@24",
    "react": "npm:react@18",
    "react-dom": "npm:react-dom@18"
  },
  "compilerOptions": {
    "lib": ["esnext", "dom", "dom.iterable", "dom.asynciterable", "deno.ns"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "jsxImportSourceTypes": "@types/react"
  },
  "nodeModulesDir": "auto",
  "exclude": [
    "coverage",
    "node_modules"
  ],
  "exports": "./src/mod.ts",
  "publish": {
    "exclude": [
      "test",
      "scripts",
      "sample",
      "node_modules",
      "npm",
      ".github",
      ".vscode"
    ]
  }
}
